# Copy this to .env and fill in your values
APP_NAME=Swasthya-Setu API
DEBUG=false

# AWS credentials (use IAM role in Lambda, not hardcode)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Amazon Bedrock model IDs
TRIAGE_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
CHATBOT_MODEL_ID=meta.llama3-8b-instruct-v1:0

# RDS PostgreSQL
DATABASE_URL=postgresql://postgres:password@your-rds-endpoint:5432/swasthya_setu
